NTFY_BASE_URL=https://ntfy.site.com
TZ=Asia/Baku
NTFY_ENABLE_LOGIN=true
NTFY_UPSTREAM_ACCESS_TOKEN=
NTFY_BEHIND_PROXY=true
# Bcrypt
# NTFY_AUTH_USERS='phil:$2a$10$YLiO8U21sX1uhZamTLJXHuxgVC0Z/GKISibrKCLohPgtG7yIxSk4C:admin,ben:$2a$10$NKbrNb7HPMjtQXWJ0f1pouw03LDLT/WzlO9VAv44x84bRCkh19h6m:user'

NTFY_ENABLE_SIGNUP=false
# run `ntfy webpush keys` to get 
NTFY_WEB_PUSH_PUBLIC_KEY=
NTFY_WEB_PUSH_PRIVATE_KEY=
NTFY_WEB_PUSH_EMAIL_ADDRESS=admin@site.com

NTFY_SMTP_SENDER_ADDR=smtp.site.com:465
NTFY_SMTP_SENDER_USER=admin@site.com
NTFY_SMTP_SENDER_PASS=changeme
NTFY_SMTP_SENDER_FROM=admin@site.com
NTFY_SMTP_SERVER_LISTEN=:465
NTFY_SMTP_SERVER_DOMAIN=ntfy.site.com

NTFY_ATTACHMENT_CACHE_DIR=/var/lib/ntfy/attachments
NTFY_AUTH_DEFAULT_ACCESS=read-write
NTFY_AUTH_FILE=/var/lib/ntfy/auth.db
NTFY_CACHE_FILE=/var/cache/ntfy/cache.db
NTFY_ATTACHMENT_TOTAL_SIZE_LIMIT=1G
NTFY_ATTACHMENT_FILE_SIZE_LIMIT=10M
NTFY_ATTACHMENT_EXPIRY_DURATION=24h
NTFY_UPSTREAM_BASE_URL=https://ntfy.sh
NTFY_CACHE_DURATION=24h
NTFY_KEEPALIVE_INTERVAL=5m
NTFY_MANAGER_INTERVAL=5m
NTFY_VISITOR_MESSAGE_DAILY_LIMIT=100
NTFY_VISITOR_ATTACHMENT_DAILY_BANDWIDTH_LIMIT=1G
NTFY_WEB_PUSH_FILE=/var/lib/ntfy/webpush.db