# =============================================================================

# -----------------------------------------------------------------------------
# CORE
# -----------------------------------------------------------------------------
_APP_ENV=production
_APP_LOCALE=en

# Main domain - the Appwrite API / Console entrypoint
# CHANGE - your main domain
_APP_DOMAIN=a.example.com
_APP_DOMAIN_TARGET=a.example.com
_APP_DOMAIN_TARGET_CNAME=a.example.com
_APP_DOMAIN_TARGET_A=YOUR_IP_ADDRESS
_APP_DOMAIN_TARGET_AAAA=
_APP_DOMAIN_TARGET_CAA=

# Functions subdomain
# CHANGE - your functions subdomain
_APP_DOMAIN_FUNCTIONS=f.example.com

# Sites subdomain
# CHANGE - your sites subdomain
_APP_DOMAIN_SITES=s.example.com

# DNS resolver for certificate validation
_APP_DNS=8.8.8.8

# Deny list - prevent custom domains pointing to these (keep sensible defaults)
_APP_CUSTOM_DOMAIN_DENY_LIST=example.com,test.com,localhost

# -----------------------------------------------------------------------------
# SECURITY / ENCRYPTION
# -----------------------------------------------------------------------------
# CHANGE - run: openssl rand -hex 32
_APP_OPENSSL_KEY_V1=changeme

# -----------------------------------------------------------------------------
# HTTPS / ROUTING
# -----------------------------------------------------------------------------
# Since your own Traefik terminates TLS upstream, keep internal force-HTTPS off.
# Your Traefik middleware (redirect-to-https@file) handles the redirect.
_APP_OPTIONS_FORCE_HTTPS=disabled
_APP_OPTIONS_ROUTER_FORCE_HTTPS=disabled
_APP_OPTIONS_FUNCTIONS_FORCE_HTTPS=disabled
_APP_OPTIONS_ROUTER_PROTECTION=disabled

# Trust X-Forwarded-For from your upstream Traefik
_APP_TRUSTED_HEADERS=x-forwarded-for

# -----------------------------------------------------------------------------
# ABUSE & RATE LIMITING
# -----------------------------------------------------------------------------
_APP_OPTIONS_ABUSE=enabled

# -----------------------------------------------------------------------------
# CONSOLE ACCESS CONTROL
# -----------------------------------------------------------------------------
# Only the first root user can register via console
_APP_CONSOLE_WHITELIST_ROOT=enabled

# Restrict console sign-ups to these email addresses (comma-separated)
# CHANGE - your admin email(s)
_APP_CONSOLE_WHITELIST_EMAILS=admin@nvroot.ch

# Optionally restrict by IP (leave blank to allow all)
_APP_CONSOLE_WHITELIST_IPS=

# Allowed console hostnames (leave blank or set to your domain)
_APP_CONSOLE_HOSTNAMES=a.example.com

# Warn on concurrent admin sessions (useful in prod)
_APP_CONSOLE_SESSION_ALERTS=enabled

# -----------------------------------------------------------------------------
# SYSTEM EMAIL
# -----------------------------------------------------------------------------
_APP_SYSTEM_EMAIL_NAME=nvroot Appwrite
_APP_SYSTEM_EMAIL_ADDRESS=noreply@nvroot.ch
_APP_SYSTEM_TEAM_EMAIL=admin@nvroot.ch
_APP_SYSTEM_SECURITY_EMAIL_ADDRESS=certs@nvroot.ch
_APP_EMAIL_SECURITY=
_APP_EMAIL_CERTIFICATES=

# -----------------------------------------------------------------------------
# SMTP (for transactional email - magic links, password resets, etc.)
# Example using SMTP relay (Mailgun, Resend, Postmark, etc.)
# -----------------------------------------------------------------------------
# CHANGE - your SMTP host
_APP_SMTP_HOST=smtp.mailgun.org
# CHANGE - 587 (STARTTLS) or 465 (SSL)
_APP_SMTP_PORT=465
# CHANGE - 'tls' or 'ssl'
_APP_SMTP_SECURE=ssl
_APP_SMTP_USERNAME=postmaster@nvroot.ch
_APP_SMTP_PASSWORD=CHANGE_ME_smtp_password

# -----------------------------------------------------------------------------
# DATABASE - MariaDB
# -----------------------------------------------------------------------------
_APP_DB_ADAPTER=mariadb
_APP_DB_HOST=mariadb
_APP_DB_PORT=3306
_APP_DB_SCHEMA=appwrite
_APP_DB_USER=appwrite
# CHANGE - run: openssl rand -hex 32
_APP_DB_PASS=changeme
_APP_DB_ROOT_PASS=changeme

# -----------------------------------------------------------------------------
# CACHE - Redis
# -----------------------------------------------------------------------------
_APP_REDIS_HOST=redis
_APP_REDIS_PORT=6379
_APP_REDIS_USER=
_APP_REDIS_PASS=

# -----------------------------------------------------------------------------
# SMS (optional - leave blank if not using SMS auth)
# Providers: twilio, vonage, textmagic, telesign, msg91, sms77, telnyx, 8x8
# Format:    sms://ACCOUNT_SID:AUTH_TOKEN@twilio
# -----------------------------------------------------------------------------
# CHANGE - e.g. sms://SID:TOKEN@twilio
_APP_SMS_PROVIDER=
# CHANGE - your sender number e.g. +1234567890
_APP_SMS_FROM=

# -----------------------------------------------------------------------------
# STORAGE
# -----------------------------------------------------------------------------
# Max single file upload size (bytes) - 30 MB default
_APP_STORAGE_LIMIT=30000000
# Max preview image size (bytes) - 20 MB default
_APP_STORAGE_PREVIEW_LIMIT=20000000
# Antivirus - enable if you run ClamAV
_APP_STORAGE_ANTIVIRUS=disabled
_APP_STORAGE_ANTIVIRUS_HOST=clamav
_APP_STORAGE_ANTIVIRUS_PORT=3310

# Storage backend: local | s3 | dospaces | backblaze | linode | wasabi
_APP_STORAGE_DEVICE=local
# If using S3-compatible storage instead, fill below and set _APP_STORAGE_DEVICE=s3
_APP_STORAGE_S3_ACCESS_KEY=
_APP_STORAGE_S3_SECRET=
_APP_STORAGE_S3_REGION=us-east-1
_APP_STORAGE_S3_BUCKET=  
_APP_STORAGE_S3_ENDPOINT=

# Other storage providers (leave blank unless used)
_APP_STORAGE_DO_SPACES_ACCESS_KEY=
_APP_STORAGE_DO_SPACES_SECRET=
_APP_STORAGE_DO_SPACES_REGION=us-east-1
_APP_STORAGE_DO_SPACES_BUCKET=
_APP_STORAGE_BACKBLAZE_ACCESS_KEY=
_APP_STORAGE_BACKBLAZE_SECRET=
_APP_STORAGE_BACKBLAZE_REGION=us-west-004
_APP_STORAGE_BACKBLAZE_BUCKET=
_APP_STORAGE_LINODE_ACCESS_KEY=
_APP_STORAGE_LINODE_SECRET=
_APP_STORAGE_LINODE_REGION=eu-central-1
_APP_STORAGE_LINODE_BUCKET=
_APP_STORAGE_WASABI_ACCESS_KEY=
_APP_STORAGE_WASABI_SECRET=
_APP_STORAGE_WASABI_REGION=eu-central-1
_APP_STORAGE_WASABI_BUCKET=

# -----------------------------------------------------------------------------
# COMPUTE / FUNCTIONS / SITES
# -----------------------------------------------------------------------------
# Max function deployment size (bytes) - 30 MB
_APP_COMPUTE_SIZE_LIMIT=30000000
_APP_FUNCTIONS_SIZE_LIMIT=30000000
# Max build artifact size (bytes) - 2 GB
_APP_FUNCTIONS_BUILD_SIZE_LIMIT=2000000000
# Execution timeout (seconds)
_APP_FUNCTIONS_TIMEOUT=900
_APP_SITES_TIMEOUT=900
# Build timeout (seconds)
_APP_COMPUTE_BUILD_TIMEOUT=900
_APP_FUNCTIONS_BUILD_TIMEOUT=900
# Max concurrent runtime containers
_APP_FUNCTIONS_CONTAINERS=10
# CPU/Memory limits (0 = no limit)
_APP_FUNCTIONS_CPUS=0
_APP_COMPUTE_CPUS=0
_APP_FUNCTIONS_MEMORY=0
_APP_COMPUTE_MEMORY=0
_APP_FUNCTIONS_MEMORY_SWAP=0

# Enabled function runtimes
# CHANGE - trim to only the runtimes you actually need to reduce attack surface
_APP_FUNCTIONS_RUNTIMES=_APP_FUNCTIONS_RUNTIMES=node-25,bun-1.3,go-1.26,python-3.14,dart-3.11,php-8.4,java-22,swift-5.10,kotlin-2.0

# Enabled sites runtimes
_APP_SITES_RUNTIMES=static-1,node-22,flutter-3.29

# Inactive container threshold (seconds) before cleanup
_APP_COMPUTE_INACTIVE_THRESHOLD=60
_APP_FUNCTIONS_INACTIVE_THRESHOLD=60

# Maintenance intervals for compute
_APP_COMPUTE_MAINTENANCE_INTERVAL=3600
_APP_FUNCTIONS_MAINTENANCE_INTERVAL=3600

# -----------------------------------------------------------------------------
# EXECUTOR
# -----------------------------------------------------------------------------
# CHANGE - run: openssl rand -hex 64
_APP_EXECUTOR_SECRET=executorsecret
_APP_EXECUTOR_HOST=http://exc1/v1
_APP_EXECUTOR_RUNTIME_NETWORK=appwrite_runtimes
_APP_COMPUTE_RUNTIMES_NETWORK=runtimes
_APP_FUNCTIONS_RUNTIMES_NETWORK=runtimes
OPEN_RUNTIMES_NETWORK=appwrite_runtimes

# Docker Hub credentials (optional, avoids pull rate limits)
_APP_DOCKER_HUB_USERNAME=
_APP_DOCKER_HUB_PASSWORD=
DOCKERHUB_PULL_USERNAME=
DOCKERHUB_PULL_PASSWORD=
DOCKERHUB_PULL_EMAIL=

# -----------------------------------------------------------------------------
# VCS - GitHub App (for Git deployments / Sites)
# See: https://appwrite.io/docs/advanced/self-hosting/functions#git
# -----------------------------------------------------------------------------
_APP_VCS_GITHUB_APP_NAME=
_APP_VCS_GITHUB_APP_ID=
_APP_VCS_GITHUB_CLIENT_ID=
_APP_VCS_GITHUB_CLIENT_SECRET=
_APP_VCS_GITHUB_PRIVATE_KEY=
#   To encode your PEM:  base64 -w 0 private-key.pem  # CHANGE - run: openssl rand -hex 32
_APP_VCS_GITHUB_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# MIGRATIONS
# -----------------------------------------------------------------------------
# Firebase migration OAuth (optional) # CHANGE if migrating from Firebase
_APP_MIGRATIONS_FIREBASE_CLIENT_ID=
_APP_MIGRATIONS_FIREBASE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# AI ASSISTANT (Appwrite Console AI helper)
# -----------------------------------------------------------------------------
# CHANGE - your OpenAI API key (sk-...)
_APP_ASSISTANT_OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# GRAPHQL
# -----------------------------------------------------------------------------
_APP_GRAPHQL_INTROSPECTION=enabled
_APP_GRAPHQL_MAX_BATCH_SIZE=10
_APP_GRAPHQL_MAX_COMPLEXITY=250
_APP_GRAPHQL_MAX_DEPTH=3

# -----------------------------------------------------------------------------
# USAGE / TELEMETRY
# -----------------------------------------------------------------------------
_APP_USAGE_STATS=enabled
_APP_USAGE_AGGREGATION_INTERVAL=30
_APP_USAGE_TIMESERIES_INTERVAL=30
_APP_USAGE_DATABASE_INTERVAL=900

# -----------------------------------------------------------------------------
# COMPRESSION
# -----------------------------------------------------------------------------
_APP_COMPRESSION_ENABLED=enabled
_APP_COMPRESSION_MIN_SIZE_BYTES=1024

# -----------------------------------------------------------------------------
# MAINTENANCE
# -----------------------------------------------------------------------------
_APP_MAINTENANCE_INTERVAL=86400
_APP_MAINTENANCE_DELAY=0
_APP_MAINTENANCE_START_TIME=03:00
# Retention periods (seconds)
_APP_MAINTENANCE_RETENTION_CACHE=2592000
_APP_MAINTENANCE_RETENTION_EXECUTION=1209600
_APP_MAINTENANCE_RETENTION_AUDIT=1209600
_APP_MAINTENANCE_RETENTION_AUDIT_CONSOLE=15778800
_APP_MAINTENANCE_RETENTION_ABUSE=86400
_APP_MAINTENANCE_RETENTION_USAGE_HOURLY=8640000
_APP_MAINTENANCE_RETENTION_SCHEDULES=86400

# -----------------------------------------------------------------------------
# WORKER CONCURRENCY
# -----------------------------------------------------------------------------
_APP_WORKER_PER_CORE=6

# -----------------------------------------------------------------------------
# LOGGING (optional - Sentry, AppSignal, etc.)
# Format: sentry://KEY@sentry.io/PROJECT_ID
# -----------------------------------------------------------------------------
_APP_LOGGING_PROVIDER=
_APP_LOGGING_CONFIG=

# -----------------------------------------------------------------------------
# SYSTEM RESPONSE FORMAT
# -----------------------------------------------------------------------------
_APP_SYSTEM_RESPONSE_FORMAT=

# -----------------------------------------------------------------------------
# BROWSER SERVICE
# -----------------------------------------------------------------------------
_APP_BROWSER_HOST=http://appwrite-browser:3000/v1